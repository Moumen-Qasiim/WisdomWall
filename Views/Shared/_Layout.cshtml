<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WisdomWall</title>
    
    <!-- Meta Descriptions for SEO -->
    <meta name="description" content="Discover, read, and share inspiring quotes on WisdomWall. Add your own quotes anonymously and join the board of wisdom." />
    
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="app-container">
        <header>
            <a class="logo" href="/">
                <!-- SVG Logo Icon -->
                <svg class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <defs>
                        <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#8f43ff" />
                            <stop offset="100%" stop-color="#00f0ff" />
                        </linearGradient>
                    </defs>
                    <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.75-2-2-2H4c-1.25 0-2 .75-2 2v4c0 1.25.75 2 2 2h3c0 4-2 6-4 6" />
                    <path d="M14 21c3 0 7-1 7-8V5c0-1.25-.75-2-2-2h-4c-1.25 0-2 .75-2 2v4c0 1.25.75 2 2 2h3c0 4-2 6-4 6" />
                </svg>
                WisdomWall
            </a>
            <div class="stats-pill" id="stats-banner">
                Wisdom Board
            </div>
        </header>

        <main role="main">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
